    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const responseText = $input.item.json.message;\n\nfunction processResult(parsed) {\n    if (!parsed.end_time && parsed.start_time) {\n        // Just add 2 hours via string parsing — no Date object needed\n        const parts = parsed.start_time.split('T');\n        const timeParts = parts[1].split(':');\n        let hour = parseInt(timeParts[0]) + 2;\n        if (hour >= 24) hour -= 24;\n        parsed.end_time = parts[0] + 'T' + String(hour).padStart(2, '0') + ':' + timeParts[1] + ':' + timeParts[2];\n    }\n    return {\n        json: parsed\n    };\n}\n\ntry {\n    return processResult(JSON.parse(responseText));\n} catch (e) {\n    try {\n        const cleanText = responseText.replace(/```json|```/g, \"\").trim();\n        return processResult(JSON.parse(cleanText));\n    } catch (err) {\n        return {\n            json: {\n                involved: false,\n                has_deadline_or_event: false,\n                error: err.message\n            }\n        };\n    }\n}"
      },
